group :jekyll_plugins do
  gem 'jekyll-assets', '~> 2.3'
  gem 'jekyll-feed', '~> 0.6'
  gem 'jekyll-minifier', '~> 0.1'
  gem 'jekyll-seo-tag', '~> 2.2'
  gem 'jekyll-sitemap', '~> 1.0'
